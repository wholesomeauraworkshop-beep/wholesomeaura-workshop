{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "thank-you.html", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/create-checkout.js", "use": "@vercel/node" },
    { "src": "api/stripe-webhook.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/create-checkout", "dest": "/api/create-checkout.js" },
    { "src": "/api/stripe-webhook", "dest": "/api/stripe-webhook.js" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/public/(.*)", "dest": "/public/$1" },
    { "src": "/thank-you.html", "dest": "/thank-you.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
